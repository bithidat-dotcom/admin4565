{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An ecommerce product listing",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "discount": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "stock": { "type": "number" },
        "sold": { "type": "number" },
        "seller": { "type": "string" },
        "seller_id": { "type": "string" },
        "is_super_sale": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customer_name": { "type": "string" },
        "whatsapp_number": { "type": "string" },
        "location": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string" },
        "seller": { "type": "string" },
        "seller_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Store products"
    },
    "orders": {
      "schema": "Order",
      "description": "Store orders"
    },
    "banners": {
      "schema": { "type": "object", "properties": {} },
      "description": "App banners"
    },
    "reviews": {
      "schema": { "type": "object", "properties": {} },
      "description": "Product reviews"
    },
    "users": {
      "schema": { "type": "object", "properties": {} },
      "description": "App users"
    },
    "sellers": {
      "schema": { "type": "object", "properties": {} },
      "description": "Seller profiles"
    }
  }
}
